{
  "_version": "1.84.0",
  "sap.app": {
    "id": "sap.suite.ui.commons.demo.tutorial",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.24.0",
      "toolsId": "cd03c7a3-136f-4f89-acb5-75f919eb49bd"
    },
    "crossNavigation": {
      "inbounds": {
        "icecream-display": {
          "semanticObject": "icecream",
          "action": "display",
          "title": "{{icecream-display.flpTitle}}",
          "subTitle": "{{icecream-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.148.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
				"sap.suite.ui.commons": {},
				"sap.suite.ui.microchart": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "sap.suite.ui.commons.demo.tutorial.i18n.i18n",
          "async": true,
					"supportedLocales": [
						""
					],
					"fallbackLocale": ""
        }
      },
      "process": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/data/ProcessFlowData.json"
			},
			"business": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/data/BusinessData.json"
			},
			"suppliers": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/data/Suppliers.json"
			},
			"reviews": {
				"type": "sap.ui.model.json.JSONModel",
				"uri": "model/data/Reviews.json"
			}
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "tutorialApp",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "sap.suite.ui.commons.demo.tutorial.view",
        "async": true,
        "viewPath": "sap.suite.ui.commons.demo.tutorial.view",
        "bypassed": {
					"target": [
						"launchpad"
					]
				}
      },
      "routes": [
        {
          "pattern": "",
          "name": "home",
          "target": "startpage"
        },
        {
          "pattern": "processFlow",
          "name": "processFlow",
          "target": "processFlow"
        },
        {
          "pattern": "chartContainer",
          "name": "chartContainer",
          "target": "chartContainer"
        },
        {
          "pattern": "reviews",
          "name": "reviews",
          "target": "reviews"
        }
      ],
      "targets": {
				"startpage": {
					"viewName": "Startpage",
					"viewLevel": 0
				},
				"processFlow": {
					"viewName": "ProcessFlow",
					"viewLevel": 1
				},
				"chartContainer": {
					"viewName": "ChartContainer",
					"viewLevel": 1
				},
				"reviews": {
					"viewName": "Reviews",
					"viewLevel": 1
				}
      }
    },
    "rootView": {
      "viewName": "sap.suite.ui.commons.demo.tutorial.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "sapsuiteuicommonsdemotutorial"
  }
}
