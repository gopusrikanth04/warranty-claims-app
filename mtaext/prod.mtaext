_schema-version: "3.2"
ID: sapsuiteuicommonsdemotutorial-prod

extends: sapsuiteuicommonsdemotutorial

resources:

  - name: sapsuiteuicommonsdemotutorial-destination-service
    parameters:
      service-name: sapsuiteuicommonsdemotutorial-destination-service-prod

  - name: sapsuiteuicommonsdemotutorial-uaa
    parameters:
      service-name: sapsuiteuicommonsdemotutorial-xsuaa-service-prod
      config:
        xsappname: sapsuiteuicommonsdemotutorial-prod

  - name: sapsuiteuicommonsdemotutorial-repo-host
    parameters:
      service-name: sapsuiteuicommonsdemotutorial-html5-service-prod

      
modules:
  - name: sapsuiteuicommonsdemotutorial-destination-content
    parameters:
      content:
        instance:
          destinations:
            - Name: sapsuiteuicommonsdemotutorial_html_repo_host
              ServiceInstanceName: sapsuiteuicommonsdemotutorial-html5-service-prod
              ServiceKeyName: sapsuiteuicommonsdemotutorial-repo-host-key
              sap.cloud.service: sapsuiteuicommonsdemotutorial

            - Authentication: OAuth2UserTokenExchange
              Name: sapsuiteuicommonsdemotutorial_uaa
              ServiceInstanceName: sapsuiteuicommonsdemotutorial-xsuaa-service-prod
              ServiceKeyName: sapsuiteuicommonsdemotutorial-uaa-key
              sap.cloud.service: sapsuiteuicommonsdemotutorial